  "scripts": {
    "start": "env-cmd -f ../../.env react-scripts start",
    "start-frontend": "react-scripts start",
    "build": "env-cmd -f ../../.env react-scripts build && node scripts/generate-version.js",
    "openshift_build": "react-scripts build && node scripts/generate-version.js",
    "test": "env-cmd -f ../../.env react-scripts test",
    "eject": "env-cmd -f ../../.env react-scripts eject",
    "lint": "eslint ./",
    "lint-fix": "eslint ./ --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "./node_modules/.bin/lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "./node_modules/.bin/prettier --write",
      "./node_modules/.bin/eslint --fix",
      "git add"
    ],
    "*.{html,css,less,ejs}": [
      "./node_modules/.bin/prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
